{
  "name": "Order",
  "type": "object",
  "properties": {
    "service_id": {
      "type": "string",
      "description": "Related service ID"
    },
    "service_title": {
      "type": "string",
      "description": "Service title at time of order"
    },
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "description": "Order amount"
    },
    "notes": {
      "type": "string",
      "description": "Customer notes or requirements"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "in_progress",
        "completed",
        "cancelled"
      ],
      "default": "pending"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "unpaid",
        "paid",
        "refunded"
      ],
      "default": "unpaid"
    }
  },
  "required": [
    "service_id",
    "customer_email"
  ]
}