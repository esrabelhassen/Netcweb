{
  "name": "Service",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Service title"
    },
    "description": {
      "type": "string",
      "description": "Short description"
    },
    "long_description": {
      "type": "string",
      "description": "Detailed description (rich text)"
    },
    "category_id": {
      "type": "string",
      "description": "Related category ID"
    },
    "price": {
      "type": "number",
      "description": "Service price (0 = contact for quote)"
    },
    "price_label": {
      "type": "string",
      "description": "Price display text e.g. 'Starting at $99'"
    },
    "type": {
      "type": "string",
      "enum": [
        "dev",
        "non-dev"
      ],
      "default": "dev",
      "description": "Service type"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Service image URLs"
    },
    "cta_type": {
      "type": "string",
      "enum": [
        "buy",
        "request",
        "contact"
      ],
      "default": "contact",
      "description": "Call to action type"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of features/deliverables"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive"
      ],
      "default": "active"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "category_id"
  ]
}